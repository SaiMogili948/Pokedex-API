  /* States */
  .loading {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    min-height: 300px; gap: 1rem;
  }

  .spinner {
    width: 40px; height: 40px;
    border: 2px solid #1e1e2e;
    border-top-color: #FF6B35;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .loading p { color: #444; font-size: 0.85rem; letter-spacing: 0.15em; text-transform: uppercase; }

  .error {
    text-align: center; padding: 3rem 1rem;
  }

  .error h2 { font-family: 'Bebas Neue', sans-serif; font-size: 2rem; color: #FF6B35; margin-bottom: 0.5rem; }
  .error p { color: #555; margin-bottom: 1.5rem; }

  .btn {
