const STAT_COLORS = {
  hp: "#FF6B35", attack: "#FFD54F", defense: "#4FC3F7",
  "special-attack": "#CE93D8", "special-defense": "#81C784", speed: "#80DEEA"
};

function SkeletonCard() {
  return (
    <div className="skeleton">
      <div className="skel-circle" />
      <div className="skel-line" style={{ width: "60%", height: 20, marginBottom: 10 }} />
      <div className="skel-line" style={{ width: "40%", height: 14 }} />
    </div>
  );
}

function PokemonModal({ pokemon, onClose }) {
  if (!pokemon) return null;
  const mainType = pokemon.types[0].type.name;
  const accent = typeColor(mainType);

  return (
    <div className="overlay" onClick={onClose}>
      <div className="modal" onClick={e => e.stopPropagation()}>
        <button className="modal-close" onClick={onClose}>✕</button>
        <img
          className="modal-img"
          src={pokemon.sprites.other["official-artwork"].front_default || pokemon.sprites.front_default}
          alt={pokemon.name}
        />
        <div className="modal-num">#{String(pokemon.id).padStart(4, "0")}</div>
        <div className="modal-name">{pokemon.name}</div>
        <div className="modal-types">
          {pokemon.types.map(t => (
            <span key={t.type.name} className="type-badge"
              style={{ background: typeColor(t.type.name) + "22", color: typeColor(t.type.name), border: `1px solid ${typeColor(t.type.name)}44` }}>
              {t.type.name}
            </span>
          ))}
        </div>
        <div className="modal-info">
          <div className="info-item">
            <div className="info-label">Height</div>
            <div className="info-val">{(pokemon.height / 10).toFixed(1)}m</div>
          </div>
          <div className="info-item">
            <div className="info-label">Weight</div>
            <div className="info-val">{(pokemon.weight / 10).toFixed(1)}kg</div>
          </div>
        </div>
        <div className="stats">
          {pokemon.stats.map(s => (
            <div key={s.stat.name} className="stat-row">
              <span className="stat-label">{s.stat.name}</span>
              <div className="stat-bar-bg">
                <div className="stat-bar"
                  style={{ width: `${Math.min(100, (s.base_stat / 255) * 100)}%`, background: STAT_COLORS[s.stat.name] || accent }} />
              </div>
              <span className="stat-val">{s.base_stat}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  );
}

export default function App() {
  const [pokemon, setPokemon] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);
  const [search, setSearch] = useState("");
  const [typeFilter, setTypeFilter] = useState("all");
  const [selected, setSelected] = useState(null);
  const [detailLoading, setDetailLoading] = useState(false);

  const fetchPokemon = async () => {
    setLoading(true);
    setError(null);
    try {
      const res = await fetch("https://pokeapi.co/api/v2/pokemon?limit=150");
      if (!res.ok) throw new Error("Failed to fetch");
      const data = await res.json();

      const details = await Promise.all(
        data.results.map(p => fetch(p.url).then(r => r.json()))
      );
      setPokemon(details);
    } catch (e) {
      setError(e.message);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => { fetchPokemon(); }, []);

  const allTypes = [...new Set(pokemon.flatMap(p => p.types.map(t => t.type.name)))].sort();

  const filtered = pokemon.filter(p => {
    const matchSearch = p.name.includes(search.toLowerCase());
    const matchType = typeFilter === "all" || p.types.some(t => t.type.name === typeFilter);
    return matchSearch && matchType;
  });

  const openModal = async (p) => {
    setSelected(p);
  };

  return (
    <>
      <style>{style}</style>
      <div className="app">
        <div className="header">
          <h1>Pokédex</h1>
          <p>First Generation · 150 Pokémon</p>
        </div>

        {!loading && !error && (
          <div className="controls">
            <div className="search-wrap">
              <input
                placeholder="Search Pokémon..."
                value={search}
                onChange={e => setSearch(e.target.value)}
              />
            </div>
            <select value={typeFilter} onChange={e => setTypeFilter(e.target.value)}>
              <option value="all">All Types</option>
              {allTypes.map(t => <option key={t} value={t}>{t.charAt(0).toUpperCase() + t.slice(1)}</option>)}
            </select>
          </div>
        )}

        {!loading && !error && (
          <p className="count">{filtered.length} Pokémon found</p>
        )}

        {loading && (
          <div>
            <div className="loading">
              <div className="spinner" />
              <p>Loading Pokémon...</p>
            </div>
            <div className="grid" style={{ maxWidth: 1200, margin: "0 auto" }}>
              {Array.from({ length: 12 }).map((_, i) => <SkeletonCard key={i} />)}
            </div>
          </div>
        )}

        {error && (
          <div className="error">
            <h2>Connection Error</h2>
            <p>Could not reach the Pokémon API. Check your connection.</p>
            <button className="btn" onClick={fetchPokemon}>Try Again</button>
          </div>
        )}

        {!loading && !error && (
          <div className="grid">
            {filtered.length === 0 && (
              <div className="empty">No Pokémon Found</div>
            )}
            {filtered.map((p, i) => {
              const mainType = p.types[0].type.name;
              const accent = typeColor(mainType);
              return (
                <div key={p.id} className="card"
                  style={{ animationDelay: `${Math.min(i, 20) * 0.03}s`, "--accent": accent }}
                  onClick={() => openModal(p)}>
                  <div className="card-num">#{String(p.id).padStart(4, "0")}</div>
                  <img
                    src={p.sprites.other["official-artwork"].front_default || p.sprites.front_default}
                    alt={p.name}
                    loading="lazy"
                  />
                  <div className="card-name">{p.name}</div>
                  <div className="types">
                    {p.types.map(t => (
                      <span key={t.type.name} className="type-badge"
                        style={{ background: typeColor(t.type.name) + "22", color: typeColor(t.type.name) }}>
                        {t.type.name}
                      </span>
                    ))}
                  </div>
                </div>
              );
            })}
          </div>
        )}

        {selected && <PokemonModal pokemon={selected} onClose={() => setSelected(null)} />}
      </div>
    </>
  );
}
